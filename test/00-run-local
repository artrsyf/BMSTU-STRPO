#!/usr/bin/env sh
set -eu

docker build -t drivingschool-simodo .
docker rm -f drivingschool-simodo-local >/dev/null 2>&1 || true

docker run -d --name drivingschool-simodo-local \
  -p 8081:8081 \
  -p 8082:8082 \
  -p 8083:8083 \
  -v "$PWD":/workspace \
  drivingschool-simodo sh -lc '
    mkdir -p /tmp/simodo/bin \
      /tmp/simodo/data/stellar \
      /tmp/simodo/data/contracts \
      /tmp/simodo/tmp/logs/work \
      /tmp/simodo/tmp/logs \
      /tmp/simodo/db &&
    cp /etc/xdg/simodo/stellar/base-setup.json /tmp/simodo/data/stellar/base-setup.json &&
    cp /etc/xdg/simodo/stellar/station-setup.json /tmp/simodo/data/stellar/station-setup.json &&
    cp /usr/share/simodo/contracts/initial-contracts.s-script /tmp/simodo/data/contracts/initial-contracts.s-script &&
    cd /tmp/simodo/bin;
    simodo-stellar-base 2022 /tmp/simodo/db >/tmp/base.log 2>&1 &
    simodo-stellar-station 8081 /workspace/src >/tmp/students.log 2>&1 &
    simodo-stellar-station 8082 /workspace/src >/tmp/training.log 2>&1 &
    simodo-stellar-station 8083 /workspace/src >/tmp/exams.log 2>&1 &
    wait
  '

sleep 3
docker exec drivingschool-simodo-local sh -lc 'ps aux | grep simodo-stellar | grep -v grep; ss -ltnp'
